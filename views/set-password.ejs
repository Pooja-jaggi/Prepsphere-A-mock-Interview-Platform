<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PrepSphere — Set Password</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg: #050816; --blue: #00d4ff; --purple: #7b2ff7;
            --pink: #ff006e; --green: #00ff88; --white: #ffffff; --gray: #8892b0;
        }
        body {
            font-family: 'Rajdhani', sans-serif; background: var(--bg);
            min-height: 100vh; overflow-x: hidden;
            display: flex; align-items: center; justify-content: center; padding: 40px 20px;
        }
        .bg-stars {
            position: fixed; inset: 0; z-index: 0;
            background:
                radial-gradient(600px 600px at 70% 20%, rgba(0,212,255,0.08) 0%, transparent 70%),
                radial-gradient(500px 500px at 20% 80%, rgba(123,47,247,0.1) 0%, transparent 70%),
                #050816;
        }
        .bg-grid {
            position: fixed; inset: 0; z-index: 0;
            background-image: linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
            background-size: 60px 60px; animation: gridPan 25s linear infinite;
        }
        @keyframes gridPan { to { background-position: 60px 60px; } }
        .scanlines {
            position: fixed; inset: 0; z-index: 2; pointer-events: none;
            background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,212,255,0.006) 3px, rgba(0,212,255,0.006) 4px);
        }
        .doodle-layer { position: fixed; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }
        .doodle { position: absolute; opacity: 0; animation: doodleFloat linear infinite; }
        @keyframes doodleFloat {
            0% { transform: translateY(105vh) rotate(0deg); opacity: 0; }
            6% { opacity: 1; } 50% { transform: translateY(50vh) rotate(6deg); opacity: 0.18; }
            94% { opacity: 0.1; } 100% { transform: translateY(-5vh) rotate(-4deg); opacity: 0; }
        }
        .word-float {
            position: absolute; opacity: 0; font-family: 'Share Tech Mono', monospace;
            animation: wordUp linear infinite; pointer-events: none; white-space: nowrap;
        }
        @keyframes wordUp {
            0% { transform: translateY(105vh); opacity: 0; } 8% { opacity: 1; }
            92% { opacity: 0.6; } 100% { transform: translateY(-5vh); opacity: 0; }
        }
        .page { position: relative; z-index: 10; width: 100%; max-width: 480px; }
        .logo-wrap { text-align: center; margin-bottom: 24px; animation: fadeDown 0.8s ease both; }
        @keyframes fadeDown { from { opacity:0; transform:translateY(-20px); } to { opacity:1; transform:translateY(0); } }
        .logo-name {
            font-family: 'Orbitron', monospace; font-size: 1.4rem; font-weight: 900; letter-spacing: 4px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .logo-tag { font-family: 'Share Tech Mono', monospace; font-size: 0.65rem; color: var(--blue); letter-spacing: 3px; opacity: 0.6; margin-top: 4px; }
        .card {
            background: rgba(10,15,46,0.85); border: 1px solid rgba(0,212,255,0.15);
            border-radius: 24px; padding: 40px 36px; backdrop-filter: blur(24px);
            position: relative; overflow: hidden; animation: fadeUp 0.8s ease 0.2s both;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
        }
        @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
        .card::before {
            content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
            background: linear-gradient(90deg, transparent, var(--blue), var(--purple), transparent);
        }
        .card::after {
            content: ''; position: absolute; top: -40%; left: -20%; width: 140%; height: 100%;
            background: radial-gradient(ellipse at 50% 0%, rgba(0,212,255,0.04) 0%, transparent 60%);
            pointer-events: none;
        }
        .corner { position: absolute; width: 14px; height: 14px; }
        .c-tl { top:12px; left:12px; border-top:2px solid var(--blue); border-left:2px solid var(--blue); }
        .c-tr { top:12px; right:12px; border-top:2px solid var(--blue); border-right:2px solid var(--blue); }
        .c-bl { bottom:12px; left:12px; border-bottom:2px solid var(--purple); border-left:2px solid var(--purple); }
        .c-br { bottom:12px; right:12px; border-bottom:2px solid var(--purple); border-right:2px solid var(--purple); }
        .steps { display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 32px; }
        .step { display: flex; flex-direction: column; align-items: center; gap: 6px; }
        .step-circle {
            width: 36px; height: 36px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Orbitron', monospace; font-size: 0.75rem; font-weight: 700;
            border: 2px solid rgba(0,212,255,0.3); color: var(--gray); transition: all 0.3s ease;
        }
        .step.active .step-circle { background: linear-gradient(135deg, var(--blue), var(--purple)); border-color: transparent; color: white; box-shadow: 0 0 20px rgba(0,212,255,0.4); }
        .step.done .step-circle { background: rgba(0,255,136,0.15); border-color: var(--green); color: var(--green); }
        .step-label { font-family: 'Share Tech Mono', monospace; font-size: 0.6rem; color: var(--gray); letter-spacing: 1px; text-transform: uppercase; }
        .step.active .step-label { color: var(--blue); }
        .step.done .step-label { color: var(--green); }
        .step-line { flex: 1; height: 1px; background: rgba(0,212,255,0.15); margin: 0 8px; margin-bottom: 22px; }
        .step-line.done { background: var(--green); }

        /* Lock icon */
        .lock-wrap { text-align: center; margin-bottom: 24px; }
        .lock-circle {
            width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 16px;
            background: rgba(123,47,247,0.08); border: 2px solid rgba(123,47,247,0.25);
            display: flex; align-items: center; justify-content: center; font-size: 2rem;
            animation: lockPulse 2s ease-in-out infinite;
            box-shadow: 0 0 30px rgba(123,47,247,0.15);
        }
        @keyframes lockPulse {
            0%,100% { box-shadow: 0 0 20px rgba(123,47,247,0.15); transform: scale(1); }
            50% { box-shadow: 0 0 40px rgba(123,47,247,0.35); transform: scale(1.05); }
        }
        .card-title {
            font-family: 'Orbitron', monospace; font-size: 1.3rem; font-weight: 700;
            letter-spacing: 2px; color: var(--white); margin-bottom: 6px; text-align: center;
        }
        .card-sub { font-size: 0.95rem; color: var(--gray); margin-bottom: 28px; text-align: center; line-height: 1.6; }

        .field { margin-bottom: 20px; position: relative; }
        .field label {
            display: block; font-family: 'Share Tech Mono', monospace;
            font-size: 0.68rem; letter-spacing: 2.5px; color: var(--blue);
            margin-bottom: 8px; text-transform: uppercase;
        }
        .field input {
            width: 100%; padding: 13px 48px 13px 16px;
            background: rgba(0,212,255,0.04); border: 1px solid rgba(0,212,255,0.18);
            border-radius: 10px; color: var(--white);
            font-family: 'Rajdhani', sans-serif; font-size: 1rem; font-weight: 500;
            outline: none; transition: all 0.3s ease;
        }
        .field input::placeholder { color: rgba(136,146,176,0.45); }
        .field input:focus { border-color: var(--blue); background: rgba(0,212,255,0.07); box-shadow: 0 0 0 3px rgba(0,212,255,0.1); }
        .field input.valid { border-color: var(--green); }
        .field input.invalid { border-color: var(--pink); }

        /* Show/hide password toggle */
        .toggle-pw {
            position: absolute; right: 14px; top: 38px;
            background: none; border: none; cursor: pointer;
            color: var(--gray); font-size: 1rem; transition: color 0.2s;
        }
        .toggle-pw:hover { color: var(--blue); }

        /* Password strength bar */
        .strength-wrap { margin-top: 8px; }
        .strength-bar {
            height: 4px; border-radius: 2px;
            background: rgba(0,212,255,0.1);
            overflow: hidden; margin-bottom: 4px;
        }
        .strength-fill {
            height: 100%; border-radius: 2px; width: 0%;
            transition: all 0.4s ease;
        }
        .strength-text { font-family: 'Share Tech Mono', monospace; font-size: 0.68rem; letter-spacing: 1px; }

        /* Requirements checklist */
        .requirements { margin-bottom: 20px; display: flex; flex-direction: column; gap: 6px; }
        .req {
            display: flex; align-items: center; gap: 8px;
            font-size: 0.82rem; color: var(--gray);
            font-family: 'Share Tech Mono', monospace; font-size: 0.7rem;
            transition: color 0.3s ease;
        }
        .req-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: rgba(136,146,176,0.3); flex-shrink: 0;
            transition: all 0.3s ease;
        }
        .req.met { color: var(--green); }
        .req.met .req-dot { background: var(--green); box-shadow: 0 0 6px rgba(0,255,136,0.5); }

        .btn-create {
            width: 100%; padding: 15px; border: none; border-radius: 10px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            color: var(--white); font-family: 'Orbitron', monospace;
            font-size: 0.8rem; font-weight: 700; letter-spacing: 3px;
            text-transform: uppercase; cursor: pointer;
            position: relative; overflow: hidden; transition: all 0.3s ease;
            box-shadow: 0 8px 25px rgba(0,212,255,0.25);
        }
        .btn-create::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            transition: 0.5s;
        }
        .btn-create:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,212,255,0.45); }
        .btn-create:hover::before { left: 100%; }
        .btn-create:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    </style>
</head>
<body>

<div class="bg-stars"></div>
<div class="bg-grid"></div>
<div class="scanlines"></div>
<div class="doodle-layer" id="doodleLayer"></div>

<div class="page">
    <div class="logo-wrap">
        <div class="logo-name">PREPSPHERE</div>
        <div class="logo-tag">AI · MOCK · INTERVIEWS</div>
    </div>

    <div class="card">
        <div class="corner c-tl"></div>
        <div class="corner c-tr"></div>
        <div class="corner c-bl"></div>
        <div class="corner c-br"></div>

        <!-- Steps -->
        <div class="steps">
            <div class="step done">
                <div class="step-circle">✓</div>
                <div class="step-label">Details</div>
            </div>
            <div class="step-line done"></div>
            <div class="step done">
                <div class="step-circle">✓</div>
                <div class="step-label">Verify</div>
            </div>
            <div class="step-line done"></div>
            <div class="step active">
                <div class="step-circle">3</div>
                <div class="step-label">Password</div>
            </div>
        </div>

        <!-- Lock icon -->
        <div class="lock-wrap">
            <div class="lock-circle">🔐</div>
        </div>

        <div class="card-title">SET YOUR PASSWORD</div>
        <div class="card-sub">Almost there! Create a strong password to secure your account.</div>

        <form action="/set-password" method="POST" id="pwForm">
            <div class="field">
                <label for="password">New Password</label>
                <input type="password" id="password" name="password" placeholder="Min 8 characters" required>
                <button type="button" class="toggle-pw" onclick="togglePw('password', this)">👁</button>
                <div class="strength-wrap">
                    <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                    <div class="strength-text" id="strengthText" style="color: var(--gray);">Enter a password</div>
                </div>
            </div>

            <!-- Requirements -->
            <div class="requirements">
                <div class="req" id="req-len"><div class="req-dot"></div> At least 8 characters</div>
                <div class="req" id="req-upper"><div class="req-dot"></div> One uppercase letter</div>
                <div class="req" id="req-num"><div class="req-dot"></div> One number</div>
            </div>

            <div class="field">
                <label for="confirmpassword">Confirm Password</label>
                <input type="password" id="confirmpassword" name="confirmpassword" placeholder="Repeat your password" required>
                <button type="button" class="toggle-pw" onclick="togglePw('confirmpassword', this)">👁</button>
            </div>

            <button type="submit" class="btn-create" id="submitBtn" disabled>CREATE ACCOUNT →</button>
        </form>
    </div>
</div>

<script>
    function togglePw(id, btn) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
        btn.textContent = input.type === 'password' ? '👁' : '🙈';
    }

    const pwInput = document.getElementById('password');
    const confirmInput = document.getElementById('confirmpassword');
    const submitBtn = document.getElementById('submitBtn');
    const fill = document.getElementById('strengthFill');
    const text = document.getElementById('strengthText');

    pwInput.addEventListener('input', () => {
        const val = pwInput.value;
        const len = val.length >= 8;
        const upper = /[A-Z]/.test(val);
        const num = /[0-9]/.test(val);

        document.getElementById('req-len').classList.toggle('met', len);
        document.getElementById('req-upper').classList.toggle('met', upper);
        document.getElementById('req-num').classList.toggle('met', num);

        const score = [len, upper, num].filter(Boolean).length;
        const colors = ['#ff006e', '#ffaa00', '#00ff88'];
        const labels = ['WEAK', 'MEDIUM', 'STRONG'];
        const widths = ['33%', '66%', '100%'];

        if (val.length === 0) {
            fill.style.width = '0%';
            text.textContent = 'Enter a password';
            text.style.color = 'var(--gray)';
        } else {
            fill.style.width = widths[score - 1] || '10%';
            fill.style.background = colors[score - 1] || '#ff006e';
            text.textContent = labels[score - 1] || 'TOO SHORT';
            text.style.color = colors[score - 1] || '#ff006e';
        }
        checkMatch();
    });

    confirmInput.addEventListener('input', checkMatch);

    function checkMatch() {
        const pw = pwInput.value;
        const confirm = confirmInput.value;
        const len = pw.length >= 8;
        const upper = /[A-Z]/.test(pw);
        const num = /[0-9]/.test(pw);
        const allMet = len && upper && num;
        const matches = pw === confirm && confirm.length > 0;

        if (confirm.length > 0) {
            confirmInput.className = matches ? 'valid' : 'invalid';
        }
        submitBtn.disabled = !(allMet && matches);
    }

    // Floating doodles + words
    const layer = document.getElementById('doodleLayer');
    const words = ['Python','Flask','DSA','SQL','Arrays','React','Node.js','API','Git','OS','DBMS','Recursion','Sorting','JavaScript','REST','JWT','Stack','Queue'];
    const wordColors = ['rgba(0,212,255,','rgba(123,47,247,','rgba(0,255,136,','rgba(255,0,110,'];
    words.forEach(word => {
        const el = document.createElement('div');
        el.className = 'word-float';
        el.textContent = word;
        const color = wordColors[Math.floor(Math.random() * wordColors.length)];
        el.style.cssText = `left:${Math.random()*100}vw;font-size:${Math.random()*10+9}px;color:${color}${(Math.random()*0.35+0.15).toFixed(2)});animation-duration:${Math.random()*12+12}s;animation-delay:${Math.random()*15}s;`;
        layer.appendChild(el);
    });
    const doodles = [
        { color:'#00d4ff', html:`<svg width="60" height="50" viewBox="0 0 24 20" fill="none" stroke="#00d4ff" stroke-width="1.2" stroke-linecap="round"><rect x="2" y="2" width="20" height="13" rx="2"/><text x="7" y="12" font-size="5" fill="#00d4ff" font-family="monospace" stroke="none">&lt;/&gt;</text><path d="M0,17 Q2,15 5,15 L19,15 Q22,15 24,17 Z" fill="rgba(0,212,255,0.1)" stroke="#00d4ff"/></svg>` },
        { color:'#a855f7', html:`<svg width="58" height="50" viewBox="0 0 24 20" fill="none" stroke="#a855f7" stroke-width="1.2" stroke-linecap="round"><rect x="1" y="1" width="22" height="18" rx="2"/><line x1="1" y1="5" x2="23" y2="5"/><circle cx="4" cy="3" r="0.8" fill="#ff006e" stroke="none"/><circle cx="7" cy="3" r="0.8" fill="#ffaa00" stroke="none"/><circle cx="10" cy="3" r="0.8" fill="#00ff88" stroke="none"/><polyline points="4,10 7,13 4,16"/><line x1="9" y1="16" x2="16" y2="16"/></svg>` },
        { color:'#ff006e', html:`<svg width="55" height="45" viewBox="0 0 24 18" fill="none" stroke="#ff006e" stroke-width="2" stroke-linecap="round"><polyline points="16,2 22,9 16,16"/><polyline points="8,2 2,9 8,16"/></svg>` },
        { color:'#ffaa00', html:`<svg width="50" height="50" viewBox="0 0 22 22" fill="none" stroke="#ffaa00" stroke-width="1.2" stroke-linecap="round"><polygon points="11,2 13.8,8 20,8.7 15.5,13 17,19.5 11,16.2 5,19.5 6.5,13 2,8.7 8.2,8"/></svg>` },
        { color:'#00ff88', html:`<svg width="45" height="58" viewBox="0 0 16 22" fill="none" stroke="#00ff88" stroke-width="1.2" stroke-linecap="round"><rect x="5" y="1" width="6" height="10" rx="3"/><path d="M2,10 Q2,16 8,16 Q14,16 14,10"/><line x1="8" y1="16" x2="8" y2="20"/><line x1="5" y1="20" x2="11" y2="20"/></svg>` },
    ];
    doodles.forEach(d => {
        const el = document.createElement('div');
        el.className = 'doodle';
        el.innerHTML = d.html;
        el.style.cssText = `left:${Math.random()*95}vw;animation-duration:${Math.random()*14+14}s;animation-delay:${Math.random()*15}s;filter:drop-shadow(0 0 8px ${d.color}66);`;
        layer.appendChild(el);
    });
</script>
</body>
</html>
