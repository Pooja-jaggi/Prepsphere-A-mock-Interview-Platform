    <script>
        const layer = document.getElementById('doodleLayer');

        // Floating tech words
        const words = [
            'Python', 'Flask', 'DSA', 'SQL', 'Arrays', 'LinkedList', 'React',
            'Node.js', 'MongoDB', 'API', 'Git', 'Docker', 'OS', 'DBMS',
            'Networks', 'Recursion', 'Sorting', 'Graphs', 'Trees', 'Binary Search',
            'JavaScript', 'CSS', 'HTML', 'REST', 'JWT', 'Algorithms', 'Pointers',
            'Stack', 'Queue', 'HashMap', 'O(n)', 'OOP', 'MVC', 'Complexity'
        ];
        const wordColors = [
            'rgba(0,212,255,', 'rgba(123,47,247,',
            'rgba(0,255,136,', 'rgba(255,0,110,'
        ];
        words.forEach(word => {
            const el = document.createElement('div');
            el.className = 'word-float';
            el.textContent = word;
            const color = wordColors[Math.floor(Math.random() * wordColors.length)];
            el.style.cssText = `
            left: ${Math.random() * 100}vw;
            font-size: ${Math.random() * 10 + 9}px;
            color: ${color}${(Math.random() * 0.35 + 0.15).toFixed(2)});
            animation-duration: ${Math.random() * 12 + 12}s;
            animation-delay: ${Math.random() * 15}s;
        `;
            layer.appendChild(el);
        });

