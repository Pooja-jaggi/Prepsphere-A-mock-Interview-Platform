<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PrepSphere — Verify Email</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg: #050816; --blue: #00d4ff; --purple: #7b2ff7;
            --pink: #ff006e; --green: #00ff88; --white: #ffffff; --gray: #8892b0;
        }
        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--bg); min-height: 100vh;
            overflow-x: hidden; display: flex;
            align-items: center; justify-content: center; padding: 40px 20px;
        }
        .bg-stars {
            position: fixed; inset: 0; z-index: 0;
            background:
                radial-gradient(600px 600px at 30% 30%, rgba(123,47,247,0.1) 0%, transparent 70%),
                radial-gradient(500px 500px at 70% 70%, rgba(0,212,255,0.08) 0%, transparent 70%),
                #050816;
        }
        .bg-grid {
            position: fixed; inset: 0; z-index: 0;
            background-image: linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
            background-size: 60px 60px; animation: gridPan 25s linear infinite;
        }
        @keyframes gridPan { to { background-position: 60px 60px; } }
        .scanlines {
            position: fixed; inset: 0; z-index: 2; pointer-events: none;
            background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,212,255,0.006) 3px, rgba(0,212,255,0.006) 4px);
        }
        .doodle-layer { position: fixed; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }
        .doodle { position: absolute; opacity: 0; animation: doodleFloat linear infinite; }
        @keyframes doodleFloat {
            0% { transform: translateY(105vh) rotate(0deg); opacity: 0; }
            6% { opacity: 1; } 50% { transform: translateY(50vh) rotate(6deg); opacity: 0.18; }
            94% { opacity: 0.1; } 100% { transform: translateY(-5vh) rotate(-4deg); opacity: 0; }
        }
        .word-float {
            position: absolute; opacity: 0; font-family: 'Share Tech Mono', monospace;
            animation: wordUp linear infinite; pointer-events: none; white-space: nowrap;
        }
        @keyframes wordUp {
            0% { transform: translateY(105vh); opacity: 0; } 8% { opacity: 1; }
            92% { opacity: 0.6; } 100% { transform: translateY(-5vh); opacity: 0; }
        }
        .page { position: relative; z-index: 10; width: 100%; max-width: 480px; }
        .logo-wrap { text-align: center; margin-bottom: 24px; animation: fadeDown 0.8s ease both; }
        @keyframes fadeDown { from { opacity:0; transform:translateY(-20px); } to { opacity:1; transform:translateY(0); } }
        .logo-name {
            font-family: 'Orbitron', monospace; font-size: 1.4rem; font-weight: 900; letter-spacing: 4px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .logo-tag { font-family: 'Share Tech Mono', monospace; font-size: 0.65rem; color: var(--blue); letter-spacing: 3px; opacity: 0.6; margin-top: 4px; }
        .card {
            background: rgba(10,15,46,0.85); border: 1px solid rgba(0,212,255,0.15);
            border-radius: 24px; padding: 40px 36px; backdrop-filter: blur(24px);
            position: relative; overflow: hidden; animation: fadeUp 0.8s ease 0.2s both;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
        }
        @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
        .card::before {
            content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
            background: linear-gradient(90deg, transparent, var(--blue), var(--purple), transparent);
        }
        .card::after {
            content: ''; position: absolute; top: -40%; left: -20%; width: 140%; height: 100%;
            background: radial-gradient(ellipse at 50% 0%, rgba(0,212,255,0.04) 0%, transparent 60%);
            pointer-events: none;
        }
        .corner { position: absolute; width: 14px; height: 14px; }
        .c-tl { top:12px; left:12px; border-top:2px solid var(--blue); border-left:2px solid var(--blue); }
        .c-tr { top:12px; right:12px; border-top:2px solid var(--blue); border-right:2px solid var(--blue); }
        .c-bl { bottom:12px; left:12px; border-bottom:2px solid var(--purple); border-left:2px solid var(--purple); }
        .c-br { bottom:12px; right:12px; border-bottom:2px solid var(--purple); border-right:2px solid var(--purple); }
        .steps { display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 32px; }
        .step { display: flex; flex-direction: column; align-items: center; gap: 6px; }
        .step-circle {
            width: 36px; height: 36px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Orbitron', monospace; font-size: 0.75rem; font-weight: 700;
            border: 2px solid rgba(0,212,255,0.3); color: var(--gray); transition: all 0.3s ease;
        }
        .step.active .step-circle {
            background: linear-gradient(135deg, var(--blue), var(--purple));
            border-color: transparent; color: white; box-shadow: 0 0 20px rgba(0,212,255,0.4);
        }
        .step.done .step-circle { background: rgba(0,255,136,0.15); border-color: var(--green); color: var(--green); }
        .step-label { font-family: 'Share Tech Mono', monospace; font-size: 0.6rem; color: var(--gray); letter-spacing: 1px; text-transform: uppercase; }
        .step.active .step-label { color: var(--blue); }
        .step.done .step-label { color: var(--green); }
        .step-line { flex: 1; height: 1px; background: rgba(0,212,255,0.15); margin: 0 8px; margin-bottom: 22px; }
        .step-line.done { background: var(--green); }

        /* Email icon animation */
        .email-icon {
            text-align: center; margin-bottom: 24px;
        }
        .email-circle {
            width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 16px;
            background: rgba(0,212,255,0.08);
            border: 2px solid rgba(0,212,255,0.25);
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem;
            animation: emailPulse 2s ease-in-out infinite;
            box-shadow: 0 0 30px rgba(0,212,255,0.15);
        }
        @keyframes emailPulse {
            0%,100% { box-shadow: 0 0 20px rgba(0,212,255,0.15); transform: scale(1); }
            50% { box-shadow: 0 0 40px rgba(0,212,255,0.35); transform: scale(1.05); }
        }

        .card-title {
            font-family: 'Orbitron', monospace; font-size: 1.3rem; font-weight: 700;
            letter-spacing: 2px; color: var(--white); margin-bottom: 6px; text-align: center;
        }
        .card-sub { font-size: 0.95rem; color: var(--gray); margin-bottom: 28px; text-align: center; line-height: 1.6; }
        .card-sub span { color: var(--blue); font-weight: 600; }

        /* OTP input boxes */
        .otp-wrap {
            display: flex; gap: 10px; justify-content: center; margin-bottom: 28px;
        }
        .otp-input {
            width: 52px; height: 60px;
            background: rgba(0,212,255,0.04);
            border: 1px solid rgba(0,212,255,0.2);
            border-radius: 12px; color: var(--white);
            font-family: 'Orbitron', monospace; font-size: 1.4rem; font-weight: 700;
            text-align: center; outline: none; transition: all 0.3s ease;
            caret-color: var(--blue);
        }
        .otp-input:focus {
            border-color: var(--blue);
            background: rgba(0,212,255,0.08);
            box-shadow: 0 0 0 3px rgba(0,212,255,0.1), 0 0 20px rgba(0,212,255,0.15);
            transform: scale(1.05);
        }
        .otp-input.filled { border-color: var(--purple); background: rgba(123,47,247,0.08); }

        /* Hidden actual input */
        .hidden-input { display: none; }

        .btn-verify {
            width: 100%; padding: 15px; border: none; border-radius: 10px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            color: var(--white); font-family: 'Orbitron', monospace;
            font-size: 0.8rem; font-weight: 700; letter-spacing: 3px;
            text-transform: uppercase; cursor: pointer;
            position: relative; overflow: hidden; transition: all 0.3s ease;
            box-shadow: 0 8px 25px rgba(0,212,255,0.25);
        }
        .btn-verify::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            transition: 0.5s;
        }
        .btn-verify:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,212,255,0.45); }
        .btn-verify:hover::before { left: 100%; }

        .resend-wrap { text-align: center; margin-top: 20px; }
        .resend-wrap p { font-size: 0.9rem; color: var(--gray); }
        .resend-wrap a { color: var(--blue); text-decoration: none; font-weight: 600; transition: all 0.2s; }
        .resend-wrap a:hover { color: var(--purple); }

        .timer {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.8rem; color: var(--blue); margin-top: 8px;
            letter-spacing: 2px;
        }
    </style>
</head>
<body>

<div class="bg-stars"></div>
<div class="bg-grid"></div>
<div class="scanlines"></div>
<div class="doodle-layer" id="doodleLayer"></div>

<div class="page">
    <div class="logo-wrap">
        <div class="logo-name">PREPSPHERE</div>
        <div class="logo-tag">AI · MOCK · INTERVIEWS</div>
    </div>

    <div class="card">
        <div class="corner c-tl"></div>
        <div class="corner c-tr"></div>
        <div class="corner c-bl"></div>
        <div class="corner c-br"></div>

        <!-- Steps -->
        <div class="steps">
            <div class="step done">
                <div class="step-circle">✓</div>
                <div class="step-label">Details</div>
            </div>
            <div class="step-line done"></div>
            <div class="step active">
                <div class="step-circle">2</div>
                <div class="step-label">Verify</div>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-circle">3</div>
                <div class="step-label">Password</div>
            </div>
        </div>

        <!-- Email icon -->
        <div class="email-icon">
            <div class="email-circle">📬</div>
        </div>

        <div class="card-title">CHECK YOUR EMAIL</div>
        <div class="card-sub">
            We sent a <span>6-digit verification code</span> to your email address. Enter it below to continue.
        </div>

        <form action="/verify" method="POST" id="verifyForm">
            <!-- OTP visual boxes -->
            <div class="otp-wrap">
                <input class="otp-input" type="text" maxlength="1" id="d1">
                <input class="otp-input" type="text" maxlength="1" id="d2">
                <input class="otp-input" type="text" maxlength="1" id="d3">
                <input class="otp-input" type="text" maxlength="1" id="d4">
                <input class="otp-input" type="text" maxlength="1" id="d5">
                <input class="otp-input" type="text" maxlength="1" id="d6">
            </div>
            <!-- Hidden real input -->
            <input type="hidden" name="code" id="codeInput">
            <button type="submit" class="btn-verify">VERIFY CODE →</button>
        </form>

        <div class="resend-wrap">
            <p>Didn't receive the code? <a href="/register">Try Again</a></p>
            <div class="timer" id="timer">Code expires in: 10:00</div>
        </div>
    </div>
</div>

<script>
    // OTP input auto-advance
    const digits = ['d1','d2','d3','d4','d5','d6'];
    digits.forEach((id, i) => {
        const input = document.getElementById(id);
        input.addEventListener('input', () => {
            input.value = input.value.replace(/[^0-9]/g, '');
            if (input.value && i < 5) document.getElementById(digits[i+1]).focus();
            input.classList.toggle('filled', input.value !== '');
            updateCode();
        });
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && !input.value && i > 0) {
                document.getElementById(digits[i-1]).focus();
            }
        });
        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const paste = e.clipboardData.getData('text').replace(/[^0-9]/g,'').slice(0,6);
            paste.split('').forEach((ch, j) => {
                if (j < 6) {
                    const el = document.getElementById(digits[j]);
                    el.value = ch;
                    el.classList.add('filled');
                }
            });
            updateCode();
            if (paste.length === 6) document.getElementById(digits[5]).focus();
        });
    });

    function updateCode() {
        const code = digits.map(id => document.getElementById(id).value).join('');
        document.getElementById('codeInput').value = code;
    }

    // Timer countdown
    let seconds = 600;
    const timerEl = document.getElementById('timer');
    const countdown = setInterval(() => {
        seconds--;
        const m = Math.floor(seconds / 60).toString().padStart(2,'0');
        const s = (seconds % 60).toString().padStart(2,'0');
        timerEl.textContent = `Code expires in: ${m}:${s}`;
        if (seconds <= 0) {
            clearInterval(countdown);
            timerEl.textContent = 'Code expired. Please try again.';
            timerEl.style.color = '#ff006e';
        }
    }, 1000);

    // Floating doodles + words
    const layer = document.getElementById('doodleLayer');
    const words = ['Python','Flask','DSA','SQL','Arrays','React','Node.js','API','Git','OS','DBMS','Recursion','Sorting','JavaScript','REST','JWT','Stack','Queue'];
    const wordColors = ['rgba(0,212,255,','rgba(123,47,247,','rgba(0,255,136,','rgba(255,0,110,'];
    words.forEach(word => {
        const el = document.createElement('div');
        el.className = 'word-float';
        el.textContent = word;
        const color = wordColors[Math.floor(Math.random() * wordColors.length)];
        el.style.cssText = `left:${Math.random()*100}vw;font-size:${Math.random()*10+9}px;color:${color}${(Math.random()*0.35+0.15).toFixed(2)});animation-duration:${Math.random()*12+12}s;animation-delay:${Math.random()*15}s;`;
        layer.appendChild(el);
    });
    const doodles = [
        { color:'#00d4ff', html:`<svg width="60" height="50" viewBox="0 0 24 20" fill="none" stroke="#00d4ff" stroke-width="1.2" stroke-linecap="round"><rect x="2" y="2" width="20" height="13" rx="2"/><text x="7" y="12" font-size="5" fill="#00d4ff" font-family="monospace" stroke="none">&lt;/&gt;</text><path d="M0,17 Q2,15 5,15 L19,15 Q22,15 24,17 Z" fill="rgba(0,212,255,0.1)" stroke="#00d4ff"/></svg>` },
        { color:'#a855f7', html:`<svg width="58" height="50" viewBox="0 0 24 20" fill="none" stroke="#a855f7" stroke-width="1.2" stroke-linecap="round"><rect x="1" y="1" width="22" height="18" rx="2"/><line x1="1" y1="5" x2="23" y2="5"/><circle cx="4" cy="3" r="0.8" fill="#ff006e" stroke="none"/><circle cx="7" cy="3" r="0.8" fill="#ffaa00" stroke="none"/><circle cx="10" cy="3" r="0.8" fill="#00ff88" stroke="none"/><polyline points="4,10 7,13 4,16"/><line x1="9" y1="16" x2="16" y2="16"/></svg>` },
        { color:'#ff006e', html:`<svg width="55" height="45" viewBox="0 0 24 18" fill="none" stroke="#ff006e" stroke-width="2" stroke-linecap="round"><polyline points="16,2 22,9 16,16"/><polyline points="8,2 2,9 8,16"/></svg>` },
        { color:'#00ff88', html:`<svg width="48" height="55" viewBox="0 0 18 22" fill="none" stroke="#00ff88" stroke-width="1.2" stroke-linecap="round"><ellipse cx="9" cy="4" rx="7" ry="2.5"/><path d="M2,4 v5 Q2,11.5 9,11.5 Q16,11.5 16,9 V4"/><path d="M2,9 v5 Q2,16.5 9,16.5 Q16,16.5 16,14 V9"/><path d="M2,14 v4 Q2,20.5 9,20.5 Q16,20.5 16,18 V14"/></svg>` },
        { color:'#ffaa00', html:`<svg width="50" height="50" viewBox="0 0 22 22" fill="none" stroke="#ffaa00" stroke-width="1.2" stroke-linecap="round"><polygon points="11,2 13.8,8 20,8.7 15.5,13 17,19.5 11,16.2 5,19.5 6.5,13 2,8.7 8.2,8"/></svg>` },
    ];
    doodles.forEach(d => {
        const el = document.createElement('div');
        el.className = 'doodle';
        el.innerHTML = d.html;
        el.style.cssText = `left:${Math.random()*95}vw;animation-duration:${Math.random()*14+14}s;animation-delay:${Math.random()*15}s;filter:drop-shadow(0 0 8px ${d.color}66);`;
        layer.appendChild(el);
    });
</script>
</body>
</html>
