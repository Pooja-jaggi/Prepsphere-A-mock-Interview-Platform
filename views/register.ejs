<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PrepSphere — Register</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg: #050816; --blue: #00d4ff; --purple: #7b2ff7;
            --pink: #ff006e; --green: #00ff88; --white: #ffffff; --gray: #8892b0;
        }
        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            overflow-x: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }
        .bg-stars {
            position: fixed; inset: 0; z-index: 0;
            background:
                radial-gradient(600px 600px at 20% 20%, rgba(0,212,255,0.08) 0%, transparent 70%),
                radial-gradient(500px 500px at 80% 80%, rgba(123,47,247,0.1) 0%, transparent 70%),
                #050816;
        }
        .bg-grid {
            position: fixed; inset: 0; z-index: 0;
            background-image:
                linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
            background-size: 60px 60px;
            animation: gridPan 25s linear infinite;
        }
        @keyframes gridPan { to { background-position: 60px 60px; } }
        .scanlines {
            position: fixed; inset: 0; z-index: 2; pointer-events: none;
            background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,212,255,0.006) 3px, rgba(0,212,255,0.006) 4px);
        }
        .doodle-layer { position: fixed; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }
        .doodle { position: absolute; opacity: 0; animation: doodleFloat linear infinite; }
        @keyframes doodleFloat {
            0%   { transform: translateY(105vh) rotate(0deg); opacity: 0; }
            6%   { opacity: 1; }
            50%  { transform: translateY(50vh) rotate(6deg); opacity: 0.18; }
            94%  { opacity: 0.1; }
            100% { transform: translateY(-5vh) rotate(-4deg); opacity: 0; }
        }
        .word-float {
            position: absolute; opacity: 0;
            font-family: 'Share Tech Mono', monospace;
            animation: wordUp linear infinite;
            pointer-events: none; white-space: nowrap;
        }
        @keyframes wordUp {
            0% { transform: translateY(105vh); opacity: 0; }
            8% { opacity: 1; } 92% { opacity: 0.6; }
            100% { transform: translateY(-5vh); opacity: 0; }
        }
        .page {
            position: relative; z-index: 10;
            width: 100%; max-width: 520px;
        }
        .logo-wrap {
            text-align: center; margin-bottom: 24px;
            animation: fadeDown 0.8s ease both;
        }
        @keyframes fadeDown { from { opacity:0; transform:translateY(-20px); } to { opacity:1; transform:translateY(0); } }
        .logo-name {
            font-family: 'Orbitron', monospace;
            font-size: 1.4rem; font-weight: 900; letter-spacing: 4px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .logo-tag {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.65rem; color: var(--blue); letter-spacing: 3px; opacity: 0.6; margin-top: 4px;
        }
        .card {
            background: rgba(10,15,46,0.85);
            border: 1px solid rgba(0,212,255,0.15);
            border-radius: 24px; padding: 40px 36px;
            backdrop-filter: blur(24px); position: relative; overflow: hidden;
            animation: fadeUp 0.8s ease 0.2s both;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
        }
        @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
        .card::before {
            content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
            background: linear-gradient(90deg, transparent, var(--blue), var(--purple), transparent);
        }
        .card::after {
            content: ''; position: absolute; top: -40%; left: -20%; width: 140%; height: 100%;
            background: radial-gradient(ellipse at 50% 0%, rgba(0,212,255,0.04) 0%, transparent 60%);
            pointer-events: none;
        }
        .corner { position: absolute; width: 14px; height: 14px; }
        .c-tl { top:12px; left:12px; border-top:2px solid var(--blue); border-left:2px solid var(--blue); }
        .c-tr { top:12px; right:12px; border-top:2px solid var(--blue); border-right:2px solid var(--blue); }
        .c-bl { bottom:12px; left:12px; border-bottom:2px solid var(--purple); border-left:2px solid var(--purple); }
        .c-br { bottom:12px; right:12px; border-bottom:2px solid var(--purple); border-right:2px solid var(--purple); }

        /* Steps indicator */
        .steps {
            display: flex; align-items: center; justify-content: center;
            gap: 0; margin-bottom: 32px;
        }
        .step {
            display: flex; flex-direction: column; align-items: center; gap: 6px;
        }
        .step-circle {
            width: 36px; height: 36px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Orbitron', monospace; font-size: 0.75rem; font-weight: 700;
            border: 2px solid rgba(0,212,255,0.3); color: var(--gray);
            transition: all 0.3s ease;
        }
        .step.active .step-circle {
            background: linear-gradient(135deg, var(--blue), var(--purple));
            border-color: transparent; color: white;
            box-shadow: 0 0 20px rgba(0,212,255,0.4);
        }
        .step.done .step-circle {
            background: rgba(0,255,136,0.15);
            border-color: var(--green); color: var(--green);
        }
        .step-label {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.6rem; color: var(--gray); letter-spacing: 1px; text-transform: uppercase;
        }
        .step.active .step-label { color: var(--blue); }
        .step-line {
            flex: 1; height: 1px; background: rgba(0,212,255,0.15);
            margin: 0 8px; margin-bottom: 22px;
        }

        .card-title {
            font-family: 'Orbitron', monospace;
            font-size: 1.3rem; font-weight: 700; letter-spacing: 2px;
            color: var(--white); margin-bottom: 6px;
        }
        .card-sub { font-size: 0.95rem; color: var(--gray); margin-bottom: 28px; }

        /* Name row */
        .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

        .field { margin-bottom: 20px; }
        .field label {
            display: block;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.68rem; letter-spacing: 2.5px; color: var(--blue);
            margin-bottom: 8px; text-transform: uppercase;
        }
        .field input {
            width: 100%; padding: 13px 16px;
            background: rgba(0,212,255,0.04);
            border: 1px solid rgba(0,212,255,0.18);
            border-radius: 10px; color: var(--white);
            font-family: 'Rajdhani', sans-serif; font-size: 1rem; font-weight: 500;
            outline: none; transition: all 0.3s ease;
        }
        .field input::placeholder { color: rgba(136,146,176,0.45); }
        .field input:focus {
            border-color: var(--blue);
            background: rgba(0,212,255,0.07);
            box-shadow: 0 0 0 3px rgba(0,212,255,0.1);
        }
        .btn-register {
            width: 100%; padding: 15px; margin-top: 6px;
            border: none; border-radius: 10px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            color: var(--white); font-family: 'Orbitron', monospace;
            font-size: 0.8rem; font-weight: 700; letter-spacing: 3px;
            text-transform: uppercase; cursor: pointer;
            position: relative; overflow: hidden; transition: all 0.3s ease;
            box-shadow: 0 8px 25px rgba(0,212,255,0.25);
        }
        .btn-register::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            transition: 0.5s;
        }
        .btn-register:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,212,255,0.45); }
        .btn-register:hover::before { left: 100%; }
        .btn-register:active { transform: translateY(0); }

        .info-box {
            display: flex; gap: 12px; align-items: flex-start;
            padding: 14px 16px; margin-bottom: 24px;
            background: rgba(0,212,255,0.05);
            border: 1px solid rgba(0,212,255,0.15);
            border-radius: 10px;
        }
        .info-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 2px; }
        .info-text { font-size: 0.85rem; color: var(--gray); line-height: 1.5; }
        .info-text strong { color: var(--blue); }

        .divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
        .div-line { flex: 1; height: 1px; background: rgba(0,212,255,0.1); }
        .div-text { font-family: 'Share Tech Mono', monospace; font-size: 0.65rem; color: var(--gray); letter-spacing: 2px; }
        .links { text-align: center; }
        .links p { font-size: 0.9rem; color: var(--gray); }
        .links a { color: var(--blue); text-decoration: none; font-weight: 600; transition: all 0.2s; }
        .links a:hover { color: var(--purple); }
    </style>
</head>
<body>

<div class="bg-stars"></div>
<div class="bg-grid"></div>
<div class="scanlines"></div>
<div class="doodle-layer" id="doodleLayer"></div>

<div class="page">

    <!-- Logo -->
    <div class="logo-wrap">
        <div class="logo-name">PREPSPHERE</div>
        <div class="logo-tag">AI · MOCK · INTERVIEWS</div>
    </div>

    <!-- Card -->
    <div class="card">
        <div class="corner c-tl"></div>
        <div class="corner c-tr"></div>
        <div class="corner c-bl"></div>
        <div class="corner c-br"></div>

        <!-- Steps -->
        <div class="steps">
            <div class="step active">
                <div class="step-circle">1</div>
                <div class="step-label">Details</div>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-circle">2</div>
                <div class="step-label">Verify</div>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-circle">3</div>
                <div class="step-label">Password</div>
            </div>
        </div>

        <div class="card-title">CREATE ACCOUNT</div>
        <div class="card-sub">Start your AI-powered interview journey</div>

        <div class="info-box">
            <div class="info-icon">📧</div>
            <div class="info-text">A <strong>6-digit verification code</strong> will be sent to your email. Make sure you enter a valid email address.</div>
        </div>

        <form action="/register" method="POST">
            <div class="field-row">
                <div class="field">
                    <label for="firstname">First Name</label>
                    <input type="text" id="firstname" name="firstname" placeholder="Vishal" required>
                </div>
                <div class="field">
                    <label for="lastname">Last Name</label>
                    <input type="text" id="lastname" name="lastname" placeholder="Sharma" required>
                </div>
            </div>
            <div class="field">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email">
            </div>
            <button type="submit" class="btn-register">SEND VERIFICATION CODE →</button>
        </form>

        <div class="divider">
            <div class="div-line"></div>
            <div class="div-text">ALREADY HAVE AN ACCOUNT</div>
            <div class="div-line"></div>
        </div>

        <div class="links">
            <p><a href="/login">Sign In →</a></p>
        </div>
    </div>
</div>

<script>
    const layer = document.getElementById('doodleLayer');
    const words = [
        'Python','Flask','DSA','SQL','Arrays','LinkedList','React',
        'Node.js','MongoDB','API','Git','Docker','OS','DBMS',
        'Networks','Recursion','Sorting','Graphs','Trees','Binary Search',
        'JavaScript','CSS','HTML','REST','JWT','Algorithms','Stack','Queue'
    ];
    const wordColors = ['rgba(0,212,255,','rgba(123,47,247,','rgba(0,255,136,','rgba(255,0,110,'];
    words.forEach(word => {
        const el = document.createElement('div');
        el.className = 'word-float';
        el.textContent = word;
        const color = wordColors[Math.floor(Math.random() * wordColors.length)];
        el.style.cssText = `left:${Math.random()*100}vw;font-size:${Math.random()*10+9}px;color:${color}${(Math.random()*0.35+0.15).toFixed(2)});animation-duration:${Math.random()*12+12}s;animation-delay:${Math.random()*15}s;`;
        layer.appendChild(el);
    });
    const doodles = [
        { color:'#00d4ff', html:`<svg width="60" height="50" viewBox="0 0 24 20" fill="none" stroke="#00d4ff" stroke-width="1.2" stroke-linecap="round"><rect x="2" y="2" width="20" height="13" rx="2"/><text x="7" y="12" font-size="5" fill="#00d4ff" font-family="monospace" stroke="none">&lt;/&gt;</text><path d="M0,17 Q2,15 5,15 L19,15 Q22,15 24,17 Z" fill="rgba(0,212,255,0.1)" stroke="#00d4ff"/></svg>` },
        { color:'#a855f7', html:`<svg width="58" height="50" viewBox="0 0 24 20" fill="none" stroke="#a855f7" stroke-width="1.2" stroke-linecap="round"><rect x="1" y="1" width="22" height="18" rx="2"/><line x1="1" y1="5" x2="23" y2="5"/><circle cx="4" cy="3" r="0.8" fill="#ff006e" stroke="none"/><circle cx="7" cy="3" r="0.8" fill="#ffaa00" stroke="none"/><circle cx="10" cy="3" r="0.8" fill="#00ff88" stroke="none"/><polyline points="4,10 7,13 4,16"/><line x1="9" y1="16" x2="16" y2="16"/></svg>` },
        { color:'#ff006e', html:`<svg width="55" height="45" viewBox="0 0 24 18" fill="none" stroke="#ff006e" stroke-width="2" stroke-linecap="round"><polyline points="16,2 22,9 16,16"/><polyline points="8,2 2,9 8,16"/></svg>` },
        { color:'#00ff88', html:`<svg width="48" height="55" viewBox="0 0 18 22" fill="none" stroke="#00ff88" stroke-width="1.2" stroke-linecap="round"><ellipse cx="9" cy="4" rx="7" ry="2.5"/><path d="M2,4 v5 Q2,11.5 9,11.5 Q16,11.5 16,9 V4"/><path d="M2,9 v5 Q2,16.5 9,16.5 Q16,16.5 16,14 V9"/><path d="M2,14 v4 Q2,20.5 9,20.5 Q16,20.5 16,18 V14"/></svg>` },
        { color:'#a855f7', html:`<svg width="55" height="55" viewBox="0 0 22 22" fill="none" stroke="#a855f7" stroke-width="1.1" stroke-linecap="round"><rect x="6" y="6" width="10" height="10" rx="1.5"/><line x1="8" y1="6" x2="8" y2="3"/><line x1="11" y1="6" x2="11" y2="3"/><line x1="14" y1="6" x2="14" y2="3"/><line x1="8" y1="16" x2="8" y2="19"/><line x1="11" y1="16" x2="11" y2="19"/><line x1="14" y1="16" x2="14" y2="19"/><line x1="3" y1="8" x2="6" y2="8"/><line x1="3" y1="11" x2="6" y2="11"/><line x1="3" y1="14" x2="6" y2="14"/><line x1="16" y1="8" x2="19" y2="8"/><line x1="16" y1="11" x2="19" y2="11"/><line x1="16" y1="14" x2="19" y2="14"/></svg>` },
        { color:'#00d4ff', html:`<svg width="48" height="58" viewBox="0 0 16 20" fill="none" stroke="#00d4ff" stroke-width="1.2" stroke-linecap="round"><circle cx="5" cy="4" r="2"/><circle cx="5" cy="16" r="2"/><circle cx="12" cy="7" r="2"/><line x1="5" y1="6" x2="5" y2="14"/><path d="M5,6 Q5,4 12,7"/></svg>` },
        { color:'#ffaa00', html:`<svg width="50" height="50" viewBox="0 0 22 22" fill="none" stroke="#ffaa00" stroke-width="1.2" stroke-linecap="round"><polygon points="11,2 13.8,8 20,8.7 15.5,13 17,19.5 11,16.2 5,19.5 6.5,13 2,8.7 8.2,8"/></svg>` },
        { color:'#00ff88', html:`<svg width="45" height="58" viewBox="0 0 16 22" fill="none" stroke="#00ff88" stroke-width="1.2" stroke-linecap="round"><rect x="5" y="1" width="6" height="10" rx="3"/><path d="M2,10 Q2,16 8,16 Q14,16 14,10"/><line x1="8" y1="16" x2="8" y2="20"/><line x1="5" y1="20" x2="11" y2="20"/></svg>` },
    ];
    doodles.forEach(d => {
        const el = document.createElement('div');
        el.className = 'doodle';
        el.innerHTML = d.html;
        el.style.cssText = `left:${Math.random()*95}vw;animation-duration:${Math.random()*14+14}s;animation-delay:${Math.random()*15}s;filter:drop-shadow(0 0 8px ${d.color}66);`;
        layer.appendChild(el);
    });
</script>
</body>
</html>
