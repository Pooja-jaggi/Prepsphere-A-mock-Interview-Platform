<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PrepSphere — Dashboard</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #050816;
            --bg2: #0a0f2e;
            --bg3: #0d1433;
            --blue: #00d4ff;
            --purple: #7b2ff7;
            --pink: #ff006e;
            --green: #00ff88;
            --yellow: #ffaa00;
            --white: #ffffff;
            --gray: #8892b0;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .bg-stars {
            position: fixed;
            inset: 0;
            z-index: 0;
            background:
                radial-gradient(600px 600px at 80% 10%, rgba(123, 47, 247, 0.08) 0%, transparent 70%),
                radial-gradient(500px 500px at 10% 80%, rgba(0, 212, 255, 0.06) 0%, transparent 70%),
                #050816;
        }

        .bg-grid {
            position: fixed;
            inset: 0;
            z-index: 0;
            background-image: linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            animation: gridPan 25s linear infinite;
        }

        @keyframes gridPan {
            to {
                background-position: 60px 60px;
            }
        }

        .scanlines {
            position: fixed;
            inset: 0;
            z-index: 2;
            pointer-events: none;
            background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0, 212, 255, 0.005) 3px, rgba(0, 212, 255, 0.005) 4px);
        }

        /* ── NAV ── */
        nav {
            position: relative;
            z-index: 10;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 40px;
            border-bottom: 1px solid rgba(0, 212, 255, 0.08);
            background: rgba(5, 8, 22, 0.9);
            backdrop-filter: blur(20px);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .nav-logo-badge {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Orbitron', monospace;
            font-size: 0.7rem;
            font-weight: 900;
            color: white;
            box-shadow: 0 0 15px rgba(0, 212, 255, 0.3);
        }

        .nav-logo-text {
            font-family: 'Orbitron', monospace;
            font-size: 1.1rem;
            font-weight: 900;
            letter-spacing: 3px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .nav-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 16px;
            background: rgba(0, 212, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.1);
            border-radius: 10px;
        }

        .nav-avatar {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Orbitron', monospace;
            font-size: 0.7rem;
            font-weight: 700;
            color: white;
        }

        .nav-username {
            font-size: 0.9rem;
            color: var(--white);
            font-weight: 600;
        }

        .btn-logout {
            padding: 8px 18px;
            border-radius: 8px;
            background: rgba(255, 0, 110, 0.1);
            border: 1px solid rgba(255, 0, 110, 0.25);
            color: var(--pink);
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.72rem;
            letter-spacing: 1px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-logout:hover {
            background: rgba(255, 0, 110, 0.2);
            box-shadow: 0 0 15px rgba(255, 0, 110, 0.2);
        }

        /* ── MAIN CONTENT ── */
        .main {
            position: relative;
            z-index: 5;
            padding: 40px;
            max-width: 1300px;
            margin: 0 auto;
        }

        /* ── HEADER ── */
        .dash-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
            animation: fadeDown 0.6s ease both;
        }

        @keyframes fadeDown {
            from {
                opacity: 0;
                transform: translateY(-15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .dash-title {
            font-family: 'Orbitron', monospace;
            font-size: 2rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 2px;
            margin-bottom: 6px;
        }

        .dash-sub {
            font-size: 1rem;
            color: var(--gray);
            letter-spacing: 0.5px;
        }

        .dash-sub span {
            color: var(--blue);
            font-weight: 600;
        }

        .btn-new-interview {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 28px;
            border-radius: 12px;
            border: none;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            color: white;
            font-family: 'Orbitron', monospace;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-decoration: none;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 8px 25px rgba(0, 212, 255, 0.25);
            white-space: nowrap;
        }

        .btn-new-interview::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.12), transparent);
            transition: 0.5s;
        }

        .btn-new-interview:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(0, 212, 255, 0.45);
        }

        .btn-new-interview:hover::before {
            left: 100%;
        }

        /* ── STATS GRID ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 40px;
            animation: fadeUp 0.6s ease 0.1s both;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .stat-card {
            background: var(--bg3);
            border: 1px solid rgba(0, 212, 255, 0.1);
            border-radius: 16px;
            padding: 24px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .stat-card:nth-child(1)::before {
            background: linear-gradient(90deg, var(--blue), var(--purple));
        }

        .stat-card:nth-child(2)::before {
            background: linear-gradient(90deg, var(--purple), var(--pink));
        }

        .stat-card:nth-child(3)::before {
            background: linear-gradient(90deg, var(--green), var(--blue));
        }

        .stat-card:nth-child(4)::before {
            background: linear-gradient(90deg, var(--yellow), var(--pink));
        }

        .stat-card:hover {
            transform: translateY(-4px);
            border-color: rgba(0, 212, 255, 0.25);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        }

        .stat-icon {
            font-size: 1.8rem;
            margin-bottom: 12px;
        }

        .stat-value {
            font-family: 'Orbitron', monospace;
            font-size: 2.2rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--blue), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-label {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.7rem;
            color: var(--gray);
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        < !-- Improvement Areas --><% const allAreas=[];

        interviews.forEach(i=> {
                if (i.improvement_areas) {
                    i.improvement_areas.split(',').forEach(a=> {
                            const trimmed=a.trim();
                            if (trimmed) allAreas.push(trimmed);
                        });
                }
            });

        const areaCount= {}

        ;

        allAreas.forEach(a=> {
                areaCount[a]=(areaCount[a] || 0) + 1;
            });
        const sortedAreas=Object.entries(areaCount).sort((a, b)=> b[1] - a[1]).slice(0, 8);

        %><% if (sortedAreas.length > 0) {
            %><div style="margin-bottom: 40px; animation: fadeUp 0.6s ease 0.15s both;"><div class="section-head"><div class="section-title">FOCUS AREAS — WHERE YOU NEED TO IMPROVE</div></div><div style="display: flex; flex-wrap: wrap; gap: 14px; margin-top: 20px;"><% sortedAreas.forEach(([area, count])=> {
                    %> <div style="
 background: rgba(255, 0, 110, 0.06);
                    border: 1px solid rgba(255, 0, 110, 0.2);
                    border-radius: 14px;
                    padding: 14px 20px;
                    display: flex; flex-direction: column; gap: 6px;
                    min-width: 180px; flex: 1;
                    transition: all 0.3s ease;
                    " onmouseover=" this.style.background='rgba(255,0,110,0.12)'; this.style.transform='translateY(-3px)' "
 onmouseout="this.style.background='rgba(255,0,110,0.06)'; this.style.transform='translateY(0)'" > <div style="font-size: 0.85rem; color: #ffffff; font-weight: 600; line-height: 1.4;" > ⚠️ <%=area %> </div> <div style="font-family: 'Share Tech Mono', monospace; font-size: 0.65rem; color: var(--pink); letter-spacing: 1px;" > flagged <%=count %> time<%=count > 1 ? 's' : '' %> </div> </div> <%
                }) %></div></div><%
        }

        %>< !-- Interview History --><div class="section-head">.section-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .section-title {
            font-family: 'Orbitron', monospace;
            font-size: 1rem;
            font-weight: 700;
            color: var(--blue);
            letter-spacing: 3px;
            text-transform: uppercase;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(0, 212, 255, 0.15);
            position: relative;
            flex: 1;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 50px;
            height: 2px;
            background: var(--blue);
            box-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
        }

        /* ── INTERVIEW CARDS GRID ── */
        .interviews-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 20px;
            animation: fadeUp 0.6s ease 0.2s both;
        }

        .interview-card {
            background: var(--bg3);
            border: 1px solid rgba(0, 212, 255, 0.08);
            border-radius: 16px;
            padding: 24px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
            cursor: default;
        }

        .interview-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--blue), var(--purple));
        }

        .interview-card:hover {
            transform: translateY(-6px) rotateX(2deg);
            border-color: rgba(0, 212, 255, 0.25);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(0, 212, 255, 0.08);
        }

        .card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }

        .badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .badge-explain {
            background: rgba(0, 212, 255, 0.12);
            color: var(--blue);
            border: 1px solid rgba(0, 212, 255, 0.25);
        }

        .badge-interview {
            background: rgba(123, 47, 247, 0.12);
            color: #a855f7;
            border: 1px solid rgba(123, 47, 247, 0.25);
        }

        .badge-both {
            background: rgba(255, 0, 110, 0.12);
            color: var(--pink);
            border: 1px solid rgba(255, 0, 110, 0.25);
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.68rem;
            letter-spacing: 1px;
        }

        .status-completed {
            background: rgba(0, 255, 136, 0.1);
            color: var(--green);
            border: 1px solid rgba(0, 255, 136, 0.25);
        }

        .status-incomplete {
            background: rgba(255, 170, 0, 0.1);
            color: var(--yellow);
            border: 1px solid rgba(255, 170, 0, 0.25);
        }

        .project-url {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.75rem;
            color: var(--gray);
            margin-bottom: 16px;
            word-break: break-all;
            padding: 8px 12px;
            background: rgba(0, 212, 255, 0.04);
            border-radius: 8px;
            border: 1px solid rgba(0, 212, 255, 0.08);
        }

        /* Score donut */
        .score-row {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 14px;
        }

        .score-donut {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            background: conic-gradient(var(--blue) 0deg, rgba(0, 212, 255, 0.1) 0deg);
        }

        .score-donut-inner {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--bg3);
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
        }

        .score-num {
            font-family: 'Orbitron', monospace;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--blue);
            position: relative;
            z-index: 1;
        }

        .score-info {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .score-info p {
            font-size: 0.85rem;
            color: var(--gray);
        }

        .score-info strong {
            color: var(--white);
        }

        /* Improvement tags */
        .improvement-wrap {
            margin-top: 12px;
        }

        .improvement-label {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.65rem;
            color: var(--gray);
            letter-spacing: 2px;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .tag {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.72rem;
            background: rgba(255, 0, 110, 0.08);
            color: var(--pink);
            border: 1px solid rgba(255, 0, 110, 0.18);
            font-family: 'Share Tech Mono', monospace;
        }

        .card-date {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.68rem;
            color: rgba(136, 146, 176, 0.5);
            margin-top: 14px;
        }

        /* ── EMPTY STATE ── */
        .empty-state {
            text-align: center;
            padding: 80px 40px;
            grid-column: 1 / -1;
        }

        .empty-icon {
            font-size: 3.5rem;
            margin-bottom: 16px;
            filter: drop-shadow(0 0 20px rgba(0, 212, 255, 0.4));
        }

        .empty-title {
            font-family: 'Orbitron', monospace;
            font-size: 1.3rem;
            color: var(--blue);
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        .empty-sub {
            font-size: 1rem;
            color: var(--gray);
            margin-bottom: 28px;
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 900px) {
            .main {
                padding: 20px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .dash-header {
                flex-direction: column;
                gap: 16px;
            }

            nav {
                padding: 16px 20px;
            }
        }

        @media (max-width: 500px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }

            .interviews-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <div class="bg-stars"></div>
    <div class="bg-grid"></div>
    <div class="scanlines"></div>

    <!-- NAV -->
    <nav>
        <a href="/dashboard" class="nav-logo">
            <div class="nav-logo-badge">PS</div>
            <div class="nav-logo-text">PREPSPHERE</div>
        </a>
        <div class="nav-right">
            <div class="nav-user">
                <div class="nav-avatar">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>
                <div class="nav-username">
                    <%= user.username %>
                </div>
            </div>
            <a href="/logout" class="btn-logout">LOGOUT</a>
        </div>
    </nav>

    <!-- MAIN -->
    <div class="main">

        <!-- Header -->
        <div class="dash-header">
            <div>
                <div class="dash-title">DASHBOARD</div>
                <div class="dash-sub">Welcome back, <span>
                        <%= user.username %>
                    </span> — ready to practice?</div>
            </div>
            <a href="/interview" class="btn-new-interview">
                ⚡ START NEW INTERVIEW
            </a>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">🎯</div>
                <div class="stat-value">
                    <%= interviews.length %>
                </div>
                <div class="stat-label">Total Sessions</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">✅</div>
                <div class="stat-value">
                    <%= interviews.filter(i=> i.status === 'completed').length %>
                </div>
                <div class="stat-label">Completed</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📊</div>
                <div class="stat-value">
                    <% const completed=interviews.filter(i=> i.score !== null);
                        const avg = completed.length > 0 ? Math.round(completed.reduce((s,i) => s + i.score, 0) /
                        completed.length) : 0;
                        %>
                        <%= avg %>
                </div>
                <div class="stat-label">Avg Score</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🏆</div>
                <div class="stat-value">
                    <% const best=completed.length> 0 ? Math.max(...completed.map(i => i.score)) : 0;
                        %>
                        <%= best %>
                </div>
                <div class="stat-label">Best Score</div>
            </div>
        </div>

        <!-- Interview History -->
        <div class="section-head">
            <div class="section-title">INTERVIEW HISTORY</div>
        </div>

        <div class="interviews-grid">
            <% if (interviews.length===0) { %>
                <div class="empty-state">
                    <div class="empty-icon">🤖</div>
                    <div class="empty-title">NO INTERVIEWS YET</div>
                    <div class="empty-sub">Start your first AI mock interview and track your progress here.</div>
                    <a href="/interview" class="btn-new-interview">START FIRST INTERVIEW</a>
                </div>
                <% } else { %>
                    <% interviews.forEach(interview=> { %>
                        <div class="interview-card">
                            <div class="card-top">
                                <span class="badge badge-<%= interview.mode %>">
                                    <%= interview.mode %>
                                </span>
                                <span class="status-badge status-<%= interview.status %>">
                                    <%= interview.status %>
                                </span>
                            </div>

                            <div class="project-url">🔗 <%= interview.project_url %>
                            </div>

                            <% if (interview.score !==null) { %>
                                <div class="score-row">
                                    <div class="score-donut"
                                        style="background: conic-gradient(#00d4ff <%= interview.score * 3.6 %>deg, rgba(0,212,255,0.1) 0deg);">
                                        <div class="score-donut-inner"></div>
                                        <div class="score-num">
                                            <%= interview.score %>
                                        </div>
                                    </div>
                                    <div class="score-info">
                                        <p>Score: <strong>
                                                <%= interview.score %>/100
                                            </strong></p>
                                        <p>Confidence: <strong>
                                                <%= interview.confidence_level || 'N/A' %>
                                            </strong></p>
                                    </div>
                                </div>
                                <% } else { %>
                                    <div class="score-row">
                                        <div class="score-donut"
                                            style="background: conic-gradient(rgba(255,170,0,0.4) 0deg, rgba(255,170,0,0.1) 0deg);">
                                            <div class="score-donut-inner"></div>
                                            <div class="score-num" style="color: var(--yellow); font-size: 0.6rem;">N/A
                                            </div>
                                        </div>
                                        <div class="score-info">
                                            <p style="color: var(--yellow);">Interview not completed</p>
                                        </div>
                                    </div>
                                    <% } %>

                                        <% if (interview.improvement_areas) { %>
                                            <div class="improvement-wrap">
                                                <div class="improvement-label">Improve On</div>
                                                <div class="tags">
                                                    <% interview.improvement_areas.split(',').slice(0,3).forEach(area=>
                                                        { %>
                                                        <span class="tag">
                                                            <%= area.trim() %>
                                                        </span>
                                                        <% }) %>
                                                </div>
                                            </div>
                                            <% } %>

                                                <div class="card-date">📅 <%= interview.created_at %>
                                                </div>
                                                <div style="margin-top: 12px;">
                                                    <a href="/interviews/<%= interview.id %>/report" style="display: inline-flex; align-items: center; gap: 6px;
                              padding: 6px 14px; border-radius: 8px; font-size: 0.72rem;
                              font-family: 'Share Tech Mono', monospace; letter-spacing: 1px;
                              background: rgba(0,212,255,0.08); color: #00d4ff;
                              border: 1px solid rgba(0,212,255,0.2); text-decoration: none;
                              transition: all 0.3s ease;" onmouseover="this.style.background='rgba(0,212,255,0.18)'"
                                                        onmouseout="this.style.background='rgba(0,212,255,0.08)'">
                                                        📄 DOWNLOAD REPORT
                                                    </a>
                                                </div>
                        </div>
                        <% }) %>
                            <% } %>
        </div>

        <!-- Charts Section -->
        <div style="margin-top: 50px;">
            <div class="section-head">
                <div class="section-title">PERFORMANCE ANALYTICS</div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; margin-top: 20px;">

                <!-- Difficulty Donut -->
                <div class="stat-card" style="padding: 28px;">
                    <div
                        style="font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; color: var(--gray); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;">
                        Difficulty Breakdown</div>
                    <canvas id="difficultyChart" height="200"></canvas>
                </div>

                <!-- Mode Bar -->
                <div class="stat-card" style="padding: 28px;">
                    <div
                        style="font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; color: var(--gray); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;">
                        Avg Score by Mode</div>
                    <canvas id="modeChart" height="200"></canvas>
                </div>

                <!-- Activity Line -->
                <div class="stat-card" style="padding: 28px;">
                    <div
                        style="font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; color: var(--gray); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;">
                        Activity (Last 7 Days)</div>
                    <canvas id="activityChart" height="200"></canvas>
                </div>

            </div>
        </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const stats = <% - JSON.stringify(stats) %>;

        Chart.defaults.color = '#8892b0';
        Chart.defaults.borderColor = 'rgba(0,212,255,0.08)';

        // 1. Difficulty Donut
        new Chart(document.getElementById('difficultyChart'), {
            type: 'doughnut',
            data: {
                labels: ['Easy', 'Medium', 'Hard'],
                datasets: [{
                    data: [
                        stats.difficultyCount.Easy,
                        stats.difficultyCount.Medium,
                        stats.difficultyCount.Hard
                    ],
                    backgroundColor: ['rgba(0,255,136,0.7)', 'rgba(255,170,0,0.7)', 'rgba(255,0,110,0.7)'],
                    borderColor: ['#00ff88', '#ffaa00', '#ff006e'],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { padding: 16, font: { size: 11 } } }
                },
                cutout: '65%'
            }
        });

        // 2. Mode Bar
        new Chart(document.getElementById('modeChart'), {
            type: 'bar',
            data: {
                labels: stats.modeStats.map(m => m.mode),
                datasets: [{
                    label: 'Avg Score',
                    data: stats.modeStats.map(m => m.avg),
                    backgroundColor: ['rgba(0,212,255,0.5)', 'rgba(123,47,247,0.5)', 'rgba(255,0,110,0.5)'],
                    borderColor: ['#00d4ff', '#7b2ff7', '#ff006e'],
                    borderWidth: 1, borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: true, max: 100, grid: { color: 'rgba(0,212,255,0.05)' } },
                    x: { grid: { display: false } }
                },
                plugins: { legend: { display: false } }
            }
        });

        // 3. Activity Line
        new Chart(document.getElementById('activityChart'), {
            type: 'line',
            data: {
                labels: stats.last7.map(d => d.label.slice(5)),
                datasets: [{
                    label: 'Interviews',
                    data: stats.last7.map(d => d.count),
                    borderColor: '#7b2ff7',
                    backgroundColor: 'rgba(123,47,247,0.1)',
                    borderWidth: 2, pointBackgroundColor: '#00d4ff',
                    pointRadius: 4, fill: true, tension: 0.4
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,212,255,0.05)' } },
                    x: { grid: { display: false } }
                },
                plugins: { legend: { display: false } }
            }
        });
    </script>
</body>

</html>